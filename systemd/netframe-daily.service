[Unit]
Description=NetFRAME daily rollup (24h health summary via local LLM)
Documentation=file:/opt/netframe-monitor/netframe_daily.py
After=network-online.target ollama.service
Wants=network-online.target

[Service]
Type=oneshot
User=root
Group=root
Nice=15
ExecStart=/usr/bin/python3 /opt/netframe-monitor/netframe_daily.py
TimeoutStartSec=900
